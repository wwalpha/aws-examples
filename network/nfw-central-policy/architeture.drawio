        <mxCell id="v68" value="&lt;b&gt;Ingress flow points&lt;/b&gt;&lt;br&gt;• IGW ingress route table sends ALB public subnet CIDRs to NFW endpoints.&lt;br&gt;• NFW evaluates allow/drop before forwarding to Public ALB.&lt;br&gt;• ALB public subnet default route points back to Inbound NFW endpoint to keep return path symmetric." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0FDF4;strokeColor=#16A34A;strokeWidth=1;fontSize=12;align=left;verticalAlign=top;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="300" y="455" width="360" height="105" as="geometry" />
        </mxCell>
        <mxCell id="v69" value="&lt;b&gt;Egress flow points&lt;/b&gt;&lt;br&gt;• Workload private subnet default route points to TGW.&lt;br&gt;• Egress VPC inspects traffic with NFW.&lt;br&gt;• NAT Gateway performs outbound NAT after inspection." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0FDF4;strokeColor=#16A34A;strokeWidth=1;fontSize=12;align=left;verticalAlign=top;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="1160" y="900" width="360" height="95" as="geometry" />
        </mxCell>
        <mxCell id="v70" value="&lt;b&gt;Legend&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;color:#111827&quot;&gt;━━&lt;/span&gt; Inbound data plane&lt;br&gt;&lt;span style=&quot;color:#16A34A&quot;&gt;━━&lt;/span&gt; Egress / forwarded data plane&lt;br&gt;&lt;span style=&quot;color:#2563EB&quot;&gt;- - -&lt;/span&gt; Policy control plane&lt;br&gt;&lt;span style=&quot;color:#DB2777&quot;&gt;- - -&lt;/span&gt; Logs / observability&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Icon styles use diagrams.net AWS4 shapes where available.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#CBD5E1;strokeWidth=1;fontSize=11;align=left;verticalAlign=top;spacing=8;" vertex="1" parent="1">
